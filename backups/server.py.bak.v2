.c:hover{border-color:var(--bdh)}
.ch{display:flex;align-items:center;gap:.5rem;padding:.4rem .6rem;cursor:pointer;user-select:none}
.ch:hover{background:rgba(255,255,255,.02)}
.ci{width:28px;height:28px;border-radius:6px;flex-shrink:0}
.cn{font-size:.82rem;font-weight:600;flex-shrink:0}
.cd{font-size:.68rem;color:var(--tm);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;min-width:0}
.ch-r{margin-left:auto;display:flex;align-items:center;gap:.3rem;flex-shrink:0}
.arrow{color:var(--tm);font-size:.65rem;transition:transform .2s}
.c.open .arrow{transform:rotate(90deg)}
.ls{display:none;border-top:1px solid var(--bd);padding:.3rem .5rem}
.c.open .ls{display:block}
.lr{display:flex;align-items:center;gap:.3rem;padding:.2rem .35rem;background:var(--bg2);border:1px solid var(--bd);border-radius:4px;margin-bottom:.2rem}
.lr:last-child{margin-bottom:0}
.lr .n{flex:1;font-size:.74rem;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0}
.sdot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.sdot.on{background:var(--grn);box-shadow:0 0 4px rgba(16,185,129,.7)}
.sdot.off{background:var(--tm);opacity:.4}
.b{border:none;padding:.15rem .35rem;border-radius:3px;cursor:pointer;font-size:.68rem;font-weight:500;font-family:inherit;transition:filter .1s;display:inline-flex;align-items:center;gap:.15rem;white-space:nowrap;flex-shrink:0;line-height:1.3}
.b:hover{filter:brightness(1.2)}.b:active{filter:brightness(.9)}.b:disabled{opacity:.4;cursor:not-allowed;filter:none}
.bg{background:linear-gradient(135deg,#4facfe,#00f2fe);color:#fff;border:1px solid rgba(16,185,129,.3)}
.bk{background:rgba(245,158,11,.1);color:var(--ylw);border:1px solid rgba(245,158,11,.3)}
.bx{background:rgba(239,68,68,.1);color:var(--red);border:1px solid rgba(239,68,68,.3)}
.bs{background:linear-gradient(135deg,rgba(245,158,11,.1),rgba(239,68,68,.1));color:var(--ylw);border:1px solid rgba(245,158,11,.3);font-weight:600}
.bp{background:rgba(59,130,246,.1);color:var(--blu);border:1px solid rgba(59,130,246,.3)}
.bw{background:rgba(139,92,246,.1);color:var(--pur);border:1px solid rgba(139,92,246,.3)}
.cnt{font-size:.6rem;color:var(--tm);background:var(--bg2);border-radius:3px;padding:0 .25rem;margin-left:.15rem}
.m{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:50;align-items:center;justify-content:center;backdrop-filter:blur(8px)}
.m.on{display:flex}
.mp{background:var(--card);border:1px solid var(--bd);border-radius:.75rem;width:90%;max-width:800px;max-height:80vh;display:flex;flex-direction:column;box-shadow:0 20px 25px -5px rgba(0,0,0,.1)}
.mh{display:flex;align-items:center;justify-content:space-between;padding:.75rem 1rem;border-bottom:1px solid var(--bd);font-size:.82rem;font-weight:600}
.mh button{background:none;border:none;color:var(--tm);font-size:1.1rem;cursor:pointer;padding:.2rem;border-radius:4px}
.mh button:hover{background:var(--bg2);color:var(--t1)}
.ml{flex:1;overflow-y:auto;padding:.75rem 1rem;font-family:'SF Mono','Monaco','Inconsolata',monospace;font-size:.78rem;line-height:1.5;color:var(--t1);background:var(--bg);min-height:180px;white-space:pre-wrap;word-break:break-all}
.spinner{width:14px;height:14px;border:2px solid rgba(255,255,255,.3);border-top:2px solid #fff;border-radius:50%;animation:spin 1s linear infinite;display:inline-block}
@keyframes spin{0%{transform:rotate(0)}100%{transform:rotate(360deg)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
</style></head><body>
<header>
<h1>Mission Control</h1>
<div class="srch">
<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
<input type="text" id="search" placeholder="Search...">
</div>
<div class="hdr-r">
<span id="rc"><span class="dot off"></span>0</span>
<span id="mdl" style="font-size:.65rem;background:rgba(108,92,231,.15);border:1px solid rgba(108,92,231,.3);padding:.1rem .4rem;border-radius:4px;color:#a89ae0">model: —</span>
<span id="clk"></span>
</div>
</header>
<main id="g"></main>
<div class="m" id="mod" onclick="if(event.target===this)cm()">
<div class="mp"><div class="mh"><span id="mt">Logs</span><button onclick="cm()">&#x2715;</button></div><div class="ml" id="mb"></div></div>
</div>
<script>
const sk=io(),P=/*DATA*/;
let run={},cL=null,expanded={};
function render(){
var g=document.getElementById('g');g.innerHTML='';
var q=document.getElementById('search').value.toLowerCase();
P.forEach(function(p){
var match=!q||p.name.toLowerCase().includes(q)||p.desc.toLowerCase().includes(q)||p.launches.some(function(l){return l.name.toLowerCase().includes(q)});
if(!match)return;
var isOpen=!!expanded[p.id];
var activeN=p.launches.filter(function(l){return!!run[l.id]}).length;
var c=document.createElement('div');c.className='c'+(isOpen?' open':'');
var ico=p.svg?'<img class="ci" src="'+p.svg+'">':'<span class="ci" style="background:'+p.color+';display:flex;align-items:center;justify-content:center;font-size:1rem;color:#fff;border-radius:6px">'+(p.icon||p.name[0])+'</span>';
var sm=p.smart?'<button class="b bs" id="sm-'+p.id+'" onclick="event.stopPropagation();smart(\''+p.id+'\',this)">&#x26A1; smart</button>':'';
var cntBadge=activeN?'<span class="cnt">'+activeN+'</span>':'';
var hdr='<div class="ch" onclick="tog(\''+p.id+'\')">'+ico+'<span class="cn" style="color:'+p.color+'">'+p.name+'</span><span class="cd">'+p.desc+'</span><div class="ch-r">'+sm+cntBadge+'<span class="arrow">&#x25B6;</span></div></div>';
var rows='';
p.launches.forEach(function(l){
var on=!!run[l.id],tracked=!!l.svc;
var sd=tracked?'<span class="sdot '+(on?'on':'off')+'"></span>':'';
var port=l.port?'<button class="b bw" onclick="event.stopPropagation();window.open(\'http://localhost:'+l.port+'\')">:'+l.port+'</button>':'';
var log=tracked?'<button class="b bp" onclick="event.stopPropagation();sl(\''+l.id+'\',\''+l.name+'\')">log</button>':'';
var kill=l.port?'<button class="b bk" onclick="event.stopPropagation();kp('+l.port+',\''+l.id+'\')">kill</button>':'';
var stop=(tracked&&on)?'<button class="b bx" onclick="event.stopPropagation();stop(\''+l.id+'\')">&#x25A0;</button>':'';
var go='<button class="b bg" id="b-'+l.id+'" onclick="event.stopPropagation();launch(\''+l.id+'\',this)"'+(on?' disabled':'')+'><span id="l-'+l.id+'">'+(on?'&#x25CF;':'&#x25B6;')+'</span></button>';
rows+='<div class="lr">'+sd+'<span class="n">'+l.name+'</span>'+port+log+kill+stop+go+'</div>';
});
c.innerHTML=hdr+'<div class="ls">'+rows+'</div>';
g.appendChild(c);});
updCount();}
function tog(id){expanded[id]=!expanded[id];render();}
function updCount(){var n=Object.values(run).filter(Boolean).length;document.getElementById('rc').innerHTML='<span class="dot '+(n?'on':'off')+'"></span>'+n+' active';}
function launch(id,btn){var el=document.getElementById('l-'+id);el.innerHTML='<div class="spinner"></div>';btn.disabled=true;fetch('/api/launch',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:id})}).then(function(r){return r.json()}).then(function(d){if(!d.ok){alert(d.msg);el.innerHTML='&#x25B6;';btn.disabled=false;}else if(!d.tracked){el.innerHTML='&#x25B6;';btn.disabled=false;}}).catch(function(e){alert(e.message);el.innerHTML='&#x25B6;';btn.disabled=false;});}
function smart(pid,btn){btn.disabled=true;btn.innerHTML='<div class="spinner"></div>';fetch('/api/smart',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:pid})}).then(function(r){return r.json()}).then(function(d){btn.disabled=false;btn.innerHTML='&#x26A1; smart';if(d.ok){var m='up:'+d.launched.length;if(d.skipped.length)m+=' skip:'+d.skipped.length;btn.innerHTML='&#x26A1; '+m;setTimeout(function(){btn.innerHTML='&#x26A1; smart'},2500);}else alert(d.msg);}).catch(function(e){alert(e.message);btn.innerHTML='&#x26A1; smart';btn.disabled=false;});}
function stop(id){fetch('/api/stop',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:id})}).then(function(r){return r.json()}).then(function(d){if(!d.ok)alert(d.msg);}).catch(function(e){alert(e.message);});}
function sl(id,nm){cL=id;document.getElementById('mt').textContent=nm;document.getElementById('mb').textContent='Loading...';document.getElementById('mod').classList.add('on');fetch('/api/logs/'+id).then(function(r){return r.json()}).then(function(d){var mb=document.getElementById('mb');mb.textContent=d.lines.length?d.lines.join('\n'):'(no output)';mb.scrollTop=999999;});}
function kp(port,id){if(!confirm('Kill port '+port+'?'))return;fetch('/api/kill-port',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({port:port})}).then(function(r){return r.json()}).then(function(d){alert(d.msg);if(d.ok&&d.killed.length){delete run[id];render();}}).catch(function(e){alert(e.message);});}
function cm(){document.getElementById('mod').classList.remove('on');cL=null;}
sk.on('started',function(d){run[d.id]=true;render();});
sk.on('stopped',function(d){delete run[d.id];render();});
sk.on('log',function(d){if(cL===d.id){var m=document.getElementById('mb');m.textContent+='\n'+d.line;m.scrollTop=999999;}});
document.addEventListener('keydown',function(e){if(e.key==='Escape')cm();});
document.getElementById('search').addEventListener('input',render);
setInterval(function(){document.getElementById('clk').textContent=new Date().toLocaleTimeString()},1000);
function pollModel(){fetch('/api/model/status').then(function(r){return r.json()}).then(function(d){var el=document.getElementById('mdl');if(d.error){el.textContent='model: error';return;}var label=d.active_model=='none'?'no model':d.active_model;el.textContent='model: '+label;el.title=d.local_ready?'Local ready':'No model';el.style.color=d.local_ready?'#55efc4':'#fd79a8';el.style.borderColor=d.local_ready?'rgba(85,239,196,.3)':'rgba(253,121,168,.3)';el.style.background=d.local_ready?'rgba(85,239,196,.1)':'rgba(253,121,168,.1)';}).catch(function(){});}
pollModel();setInterval(pollModel,15000);
fetch('/api/status').then(function(r){return r.json()}).then(function(d){run=d;render();});
</script></body></html>'''
if __name__=='__main__':
    threading.Thread(target=lambda:(time.sleep(1.5),webbrowser.open('http://localhost:9000')),daemon=True).start()
    print("Mission Control -> http://localhost:9000")
    sio.run(app,host='0.0.0.0',port=9000,debug=False,allow_unsafe_werkzeug=True)
