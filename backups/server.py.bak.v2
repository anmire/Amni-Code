_procs={}
_logs={}
_lk=threading.Lock()
def _kill_port(port):
    if not port:return False
    my_pid=os.getpid()
    killed=[]
    try:
        for c in psutil.net_connections(kind='inet'):
            if c.laddr.port==port and c.status=='LISTEN' and c.pid and c.pid!=my_pid:
                try:
                    p=psutil.Process(c.pid)
                    for ch in p.children(recursive=True):
                        try:ch.kill()
                        except:pass
                    p.kill()
                    killed.append(c.pid)
                except (psutil.NoSuchProcess,psutil.AccessDenied):pass
    except (psutil.AccessDenied,OSError):pass
    if killed:time.sleep(0.5)
    return killed
_AV2_LOCK=Path(os.environ.get('LOCALAPPDATA',''))/'Reffelt'/'discord_bot.lock'
_AV2_JSON=BASE/'Azno - v2'/'json'
_SVC_TAG={'a2-dash':'dashboard','a2-optim':'optimizer','a2-discord':'discord','a2-recacher':'recacher'}
_SVC_MOD={'a2-dash':'dashboard.app','a2-optim':'core.optimizer','a2-discord':'core.discord','a2-recacher':'core.data'}
def _pid_owns(pid,mod_hint):
    try:
        p=psutil.Process(pid)
        cl=' '.join(p.cmdline())
        return mod_hint in cl
    except (psutil.NoSuchProcess,psutil.AccessDenied,psutil.ZombieProcess):
        return False
def _reset_status(sf):
    try:sf.write_text(json.dumps({"running":False,"state":"stopped","pid":None}))
    except:pass
def _try_unlock():
    import msvcrt as _ms
    if not _AV2_LOCK.exists():return True
    try:
        fh=open(_AV2_LOCK,'r+b')
        _ms.locking(fh.fileno(),_ms.LK_NBLCK,1)
        _ms.locking(fh.fileno(),_ms.LK_UNLCK,1)
        fh.close()
        _AV2_LOCK.unlink(missing_ok=True)
        return True
    except:
        try:fh.close()
        except:pass
        return False
def _clean_stale(lid):
    if lid not in _SVC_TAG:return
    tag,mod=_SVC_TAG[lid],_SVC_MOD[lid]
    sf=_AV2_JSON/f'{tag}_status.json'
    if sf.exists():
        try:
            d=json.loads(sf.read_text())
            pid=d.get('pid')
            if pid and not _pid_owns(pid,mod):_reset_status(sf)
        except:_reset_status(sf)
    if lid=='a2-discord':
        if not _try_unlock():
            try:
                d=json.loads(sf.read_text()) if sf.exists() else {}
                pid=d.get('pid')
                if pid and not _pid_owns(pid,'core.discord'):
                    try:psutil.Process(pid).kill()
                    except:pass
                    import time as _t;_t.sleep(0.5)
                    _try_unlock()
                    _reset_status(sf)
            except:pass
def _port_free(port):
    try:
        import socket
        s=socket.socket(socket.AF_INET,socket.SOCK_STREAM)
        s.settimeout(0.5)
        r=s.connect_ex(('127.0.0.1',port))
        s.close()
        return r!=0
    except:return True
def _launch(l):
    cmd=[_LAZY_PY[c]() if c in _LAZY_PY else c for c in l.get('cmd',[])] if 'cmd' in l else None
    cwd=str(BASE/l['cwd'])
    is_svc=l.get('svc',False)
    _clean_stale(l['id'])
    port=l.get('port')
    if port:
        _kill_port(port)
        for _ in range(10):
            if _port_free(port):break
            time.sleep(0.3)
        if not _port_free(port):return {"ok":False,"msg":f"Port {port} still in use"}
    if 'bat' in l:
        args=["cmd","/c","start","","/D",cwd,"cmd","/k",l['bat']]
        subprocess.Popen(args,cwd=cwd,creationflags=subprocess.CREATE_NEW_PROCESS_GROUP|0x00000008)
        return {"ok":True,"msg":"Opened in console"}
    if l.get('win') and not is_svc:
        args=["cmd","/c","start","","/D",cwd,"cmd","/k"] + cmd
        subprocess.Popen(args,cwd=cwd,creationflags=subprocess.CREATE_NEW_PROCESS_GROUP|0x00000008)
        return {"ok":True,"msg":"Opened in console"}
    lid=l['id']
    proc=subprocess.Popen(cmd,cwd=cwd,stdout=subprocess.PIPE,stderr=subprocess.STDOUT,creationflags=subprocess.CREATE_NEW_PROCESS_GROUP|subprocess.CREATE_NO_WINDOW)
    with _lk:_procs[lid]=proc;_logs[lid]=[]
    def _rd():
        try:
            for ln in iter(proc.stdout.readline,b''):
                t=ln.decode('utf-8',errors='replace').rstrip()
                with _lk:
                    buf=_logs.setdefault(lid,[])
                    buf.append(t)
                    if len(buf)>500:_logs[lid]=buf[-300:]
                sio.emit('log',{'id':lid,'line':t})
        except:pass
        finally:
            rc=proc.wait()
            with _lk:_procs.pop(lid,None)
            sio.emit('stopped',{'id':lid,'rc':rc})
    threading.Thread(target=_rd,daemon=True).start()
    sio.emit('started',{'id':lid,'pid':proc.pid})
    return {"ok":True,"pid":proc.pid,"tracked":True}
@app.route('/favicon.ico')
def favicon():
    return Response(FAVICON_BYTES, mimetype='image/svg+xml')
@app.route('/')
def index():return HTML.replace('/*DATA*/',json.dumps(P))
@app.route('/api/status')
def api_status():
    r={}
    with _lk:
        for lid,proc in list(_procs.items()):
            if proc.poll() is None:r[lid]=True
            else:_procs.pop(lid,None)
    return jsonify(r)
@app.route('/api/launch',methods=['POST'])
def api_launch():
    lid=(request.json or {}).get('id','')
    with _lk:
        if lid in _procs and _procs[lid].poll() is None:
            return jsonify({"ok":False,"msg":"Already running"})
    tgt=None
    for p in P:
        for l in p['launches']:
            if l['id']==lid:tgt=l;break
        if tgt:break
    if not tgt:return jsonify({"ok":False,"msg":"Unknown target"})
    try:return jsonify(_launch(tgt))
    except Exception as e:return jsonify({"ok":False,"msg":str(e)})
@app.route('/api/stop',methods=['POST'])
def api_stop():
    lid=(request.json or {}).get('id','')
    with _lk:proc=_procs.get(lid)
    if not proc:return jsonify({"ok":False,"msg":"Not tracked"})
    try:
        pp=psutil.Process(proc.pid)
        for c in pp.children(recursive=True):
            try:c.kill()
            except:pass
        pp.kill()
    except:pass
    with _lk:_procs.pop(lid,None)
    sio.emit('stopped',{'id':lid,'rc':-1})
    return jsonify({"ok":True})
@app.route('/api/smart',methods=['POST'])
def api_smart():
    pid=(request.json or {}).get('id','')
    proj=None
    for p in P:
        if p['id']==pid:proj=p;break
    if not proj or 'smart' not in proj:return jsonify({"ok":False,"msg":"No smart config"})
    _lmap={l['id']:l for l in proj['launches']}
    launched,skipped=[],[]
    for lid in proj['smart']:
        with _lk:
            alive=lid in _procs and _procs[lid].poll() is None
        if alive:skipped.append(lid);continue
        tgt=_lmap.get(lid)
        if not tgt:continue
        try:_launch(tgt);launched.append(lid)
        except:skipped.append(lid)
        if len(launched)>1:time.sleep(0.5)
    return jsonify({"ok":True,"launched":launched,"skipped":skipped})
@app.route('/api/model/status')
def api_model_status():
    try:return jsonify(_model_status())
    except Exception as e:return jsonify({'error':str(e)}),500
@app.route('/api/kill-port',methods=['POST'])
def api_kill_port():
    port=(request.json or {}).get('port')
    if not port or not isinstance(port,int):return jsonify({"ok":False,"msg":"Invalid port"})
    killed=_kill_port(port)
    return jsonify({"ok":True,"killed":killed,"msg":f"Killed {len(killed)} process(es) on :{port}" if killed else f"Nothing on :{port}"})
@app.route('/api/logs/<lid>')
def api_logs(lid):
    with _lk:return jsonify({"lines":list(_logs.get(lid,[]))})
@sio.on('connect')
def on_conn():
    with _lk:
        for lid,proc in _procs.items():
            if proc.poll() is None:emit('started',{'id':lid,'pid':proc.pid})
