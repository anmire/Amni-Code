<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Amni-Code</title>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0a0a0a;--panel:#111;--border:#1a1a1a;--accent:#e91e63;--accent-dim:rgba(233,30,99,0.15);--accent-glow:rgba(233,30,99,0.3);--text:#e0e0e0;--user-text:#111;--dim:#666;--gold:#ffd700;--error:#ff4444;--font:'JetBrains Mono','Fira Code','SF Mono',Consolas,monospace;--surface2:#1a1a1a;--text2:#999;--mono:var(--font)}
[data-theme="light"]{--bg:#f4f4f4;--panel:#fff;--border:#ddd;--accent:#c2185b;--accent-dim:rgba(194,24,91,0.1);--accent-glow:rgba(194,24,91,0.2);--text:#1a1a1a;--user-text:#fff;--dim:#666;--gold:#c79600;--error:#d32f2f;--surface2:#eee;--text2:#555}
body.theme-crypt{--accent:#2979ff;--accent-dim:rgba(41,121,255,0.15);--accent-glow:rgba(41,121,255,0.3)}
body.theme-haven{--accent:#7c5cfc;--accent-dim:rgba(124,92,252,0.15);--accent-glow:rgba(124,92,252,0.3)}
body.theme-ai{--accent:#ffb74d;--accent-dim:rgba(255,183,77,0.15);--accent-glow:rgba(255,183,77,0.3)}
body.theme-core{--accent:#ef5350;--accent-dim:rgba(239,83,80,0.15);--accent-glow:rgba(239,83,80,0.3)}
body.theme-explore{--accent:#00b4ff;--accent-dim:rgba(0,180,255,0.15);--accent-glow:rgba(0,180,255,0.3)}
body.theme-calc{--accent:#ff6b35;--accent-dim:rgba(255,107,53,0.15);--accent-glow:rgba(255,107,53,0.3)}
body.theme-green{--accent:#00ff9d;--accent-dim:rgba(0,255,157,0.15);--accent-glow:rgba(0,255,157,0.3)}
[data-theme="light"] body.theme-crypt{--accent:#1565c0;--accent-dim:rgba(21,101,192,0.1);--accent-glow:rgba(21,101,192,0.2)}
[data-theme="light"] body.theme-haven{--accent:#5e35b1;--accent-dim:rgba(94,53,177,0.1);--accent-glow:rgba(94,53,177,0.2)}
[data-theme="light"] body.theme-ai{--accent:#e65100;--accent-dim:rgba(230,81,0,0.1);--accent-glow:rgba(230,81,0,0.2)}
[data-theme="light"] body.theme-core{--accent:#c62828;--accent-dim:rgba(198,40,40,0.1);--accent-glow:rgba(198,40,40,0.2)}
[data-theme="light"] body.theme-explore{--accent:#0277bd;--accent-dim:rgba(2,119,189,0.1);--accent-glow:rgba(2,119,189,0.2)}
[data-theme="light"] body.theme-calc{--accent:#d84315;--accent-dim:rgba(216,67,21,0.1);--accent-glow:rgba(216,67,21,0.2)}
[data-theme="light"] body.theme-green{--accent:#00875a;--accent-dim:rgba(0,135,90,0.1);--accent-glow:rgba(0,135,90,0.2)}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--font);font-size:15px;line-height:1.7;overflow:hidden}
a{color:var(--accent);text-decoration:none;transition:opacity .2s}
a:hover{opacity:.8}
::selection{background:var(--accent);color:var(--bg)}
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--accent-dim);border-radius:3px}
.scanlines{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(233,30,99,.015) 2px,rgba(233,30,99,.015) 4px)}
[data-theme="light"] .scanlines{opacity:.3}
.grid-bg{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:-1;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:60px 60px;opacity:.15}
@keyframes pulse{0%,100%{opacity:.3;transform:scale(1)}50%{opacity:.6;transform:scale(1.02)}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-3px)}}
.app{display:flex;height:100vh;width:100vw}
.chat-col{flex:1;display:flex;flex-direction:column;min-width:0}
.diff-col{width:0;border-left:1px solid var(--border);display:flex;flex-direction:column;transition:width .3s;overflow:hidden}
.diff-col.open{width:45%}
.editor-col{width:0;border-left:1px solid var(--border);display:flex;flex-direction:column;transition:width .3s;overflow:hidden;background:var(--panel)}
.editor-col.open{width:40%}
.tab-bar{display:flex;overflow-x:auto;background:var(--bg);border-bottom:1px solid var(--border);flex-shrink:0;scrollbar-width:none}
.tab-bar::-webkit-scrollbar{display:none}
.tab{display:flex;align-items:center;gap:4px;padding:6px 12px;font-size:11px;cursor:pointer;border-right:1px solid var(--border);color:var(--dim);white-space:nowrap;max-width:160px;overflow:hidden;text-overflow:ellipsis;user-select:none}
.tab:hover{color:var(--text);background:var(--accent-dim)}
.tab.active{color:var(--accent);background:var(--panel);border-bottom:2px solid var(--accent)}
.tab .tab-close{opacity:0;margin-left:4px;font-size:9px;line-height:1;padding:2px 4px;border-radius:3px;transition:opacity .15s}
.tab:hover .tab-close,.tab.active .tab-close{opacity:.6}
.tab .tab-close:hover{opacity:1;background:var(--error);color:#fff}
.cmd-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.5);z-index:9998;display:none}
.cmd-overlay.open{display:block}
.cmd-palette{position:fixed;top:15%;left:50%;transform:translateX(-50%);width:500px;max-width:90vw;background:var(--panel);border:1px solid var(--border);border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.5);z-index:9999;display:none;overflow:hidden}
.cmd-palette.open{display:block}
.cmd-palette input{width:100%;padding:14px 16px;background:transparent;border:none;border-bottom:1px solid var(--border);color:var(--text);font-family:var(--font);font-size:14px;outline:none}
.cmd-list{max-height:300px;overflow-y:auto}
.cmd-item{padding:10px 16px;cursor:pointer;font-size:13px;display:flex;justify-content:space-between;align-items:center;color:var(--text)}
.cmd-item:hover,.cmd-item.selected{background:var(--accent-dim);color:var(--accent)}
.cmd-item .cmd-key{font-size:10px;color:var(--dim);padding:2px 6px;border:1px solid var(--border);border-radius:3px}
.status-bar{display:flex;align-items:center;justify-content:space-between;padding:2px 16px;background:var(--accent);color:#fff;font-size:11px;flex-shrink:0;gap:12px;height:24px;font-family:var(--font)}
.status-bar .status-left,.status-bar .status-right{display:flex;align-items:center;gap:12px}
.status-bar .status-item{cursor:default;white-space:nowrap;opacity:.9}
.status-bar .status-item:hover{opacity:1}
.toast-container{position:fixed;bottom:36px;right:16px;z-index:9997;display:flex;flex-direction:column-reverse;gap:6px;pointer-events:none}
.toast{padding:10px 18px;background:var(--panel);border:1px solid var(--border);border-radius:8px;font-size:12px;color:var(--text);box-shadow:0 4px 16px rgba(0,0,0,.4);pointer-events:auto;animation:toastIn .25s ease-out;max-width:360px}
.toast.fade-out{animation:toastOut .25s ease-in forwards}
@keyframes toastIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes toastOut{from{opacity:1;transform:translateY(0)}to{opacity:0;transform:translateY(12px)}}
.breadcrumbs{display:flex;align-items:center;gap:4px;padding:4px 16px;font-size:11px;color:var(--dim);background:var(--bg);border-bottom:1px solid var(--border);overflow-x:auto;white-space:nowrap;flex-shrink:0}
.breadcrumbs span{cursor:pointer;transition:color .15s}
.breadcrumbs span:hover{color:var(--accent)}
.breadcrumbs .bc-sep{color:var(--border);cursor:default}
.breadcrumbs .bc-sep:hover{color:var(--border)}
.qo-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.5);z-index:9996;display:none}
.qo-overlay.open{display:block}
.qo-palette{position:fixed;top:12%;left:50%;transform:translateX(-50%);width:520px;max-width:90vw;background:var(--panel);border:1px solid var(--border);border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.5);z-index:9997;display:none;overflow:hidden}
.qo-palette.open{display:block}
.qo-palette input{width:100%;padding:14px 16px;background:transparent;border:none;border-bottom:1px solid var(--border);color:var(--text);font-family:var(--font);font-size:14px;outline:none}
.qo-list{max-height:320px;overflow-y:auto}
.qo-item{padding:8px 16px;cursor:pointer;font-size:12px;display:flex;justify-content:space-between;align-items:center;color:var(--text)}
.qo-item:hover,.qo-item.selected{background:var(--accent-dim);color:var(--accent)}
.qo-item .qo-path{font-size:10px;color:var(--dim);margin-left:8px;overflow:hidden;text-overflow:ellipsis}
.theme-cycle{background:none;border:1px solid var(--border);border-radius:4px;padding:4px 10px;cursor:pointer;color:var(--dim);font-family:var(--font);font-size:.65rem;letter-spacing:1px;transition:all .2s;text-transform:uppercase}
.theme-cycle:hover{border-color:var(--accent);color:var(--accent)}
.sidebar{width:220px;border-right:1px solid var(--border);background:var(--panel);display:flex;flex-direction:column;overflow:hidden;flex-shrink:0}
.sidebar-header{padding:12px 16px;border-bottom:1px solid var(--border);font-weight:600;font-size:13px;color:var(--accent)}
.sidebar-body{flex:1;overflow-y:auto;padding:4px 6px;font-size:12px}
.sb-item{padding:2px 6px;cursor:pointer;border-radius:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.7}
.sb-item:hover{background:var(--surface2);color:var(--accent)}
.sb-dir{color:var(--accent);font-family:var(--mono)}
.sb-file{color:var(--text2);font-family:var(--mono)}
.sb-up{color:var(--dim);font-size:11px}
.sb-path{font-size:10px;color:var(--dim);padding:4px 6px 6px;word-break:break-all;border-bottom:1px solid var(--border);margin-bottom:4px}
.editor-header{padding:12px 16px;border-bottom:1px solid var(--border);background:var(--panel);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.editor-body{flex:1;overflow:hidden;position:relative}
.header{display:flex;align-items:center;padding:12px 20px;border-bottom:1px solid var(--border);background:var(--panel);flex-shrink:0;gap:12px;backdrop-filter:blur(12px)}.cwd-info{font-size:12px;color:var(--dim);display:flex;align-items:center;gap:5px;background:var(--accent-dim);padding:3px 10px;border-radius:999px;border:1px solid var(--border);flex-shrink:0}.header h1{font-size:16px;font-weight:600;letter-spacing:-.3px}.header h1 span{color:var(--accent);font-weight:700}.header-actions{margin-left:auto;display:flex;gap:8px;align-items:center}
.icon-btn{background:none;border:1px solid var(--border);color:var(--dim);width:34px;height:34px;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
.icon-btn:hover{border-color:var(--accent);color:var(--accent)}
.icon-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}
.messages{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:16px}
.messages::-webkit-scrollbar{width:6px}
.messages::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.msg{max-width:85%;padding:14px 18px;border-radius:14px;line-height:1.6;font-size:14px;word-wrap:break-word}
.msg.user{align-self:flex-end;background:var(--accent);color:var(--user-text);border-bottom-right-radius:4px}
.msg.assistant{align-self:flex-start;background:var(--panel);border-bottom-left-radius:4px;border:1px solid var(--border)}
.msg.assistant pre{background:var(--bg);padding:12px;border-radius:8px;overflow-x:auto;margin:8px 0;font-family:var(--font);font-size:13px;line-height:1.5}
.msg.assistant code{font-family:var(--font);font-size:13px;background:var(--bg);padding:2px 6px;border-radius:4px}
.msg.assistant pre code{background:none;padding:0}
.msg.system{align-self:center;background:transparent;color:var(--dim);font-size:13px;text-align:center;padding:8px}
.tool-badge{display:inline-flex;align-items:center;gap:4px;font-size:11px;padding:3px 8px;border-radius:6px;margin:2px 4px 2px 0;font-family:var(--font)}
.tool-badge.success{background:#3ddc8422;color:#3ddc84;border:1px solid #3ddc8433}
.tool-badge.error{background:#ff5c5c22;color:#ff5c5c;border:1px solid #ff5c5c33}
.tool-group{margin:8px 0;padding:10px;background:var(--bg);border-radius:8px;border:1px solid var(--border)}
.tool-detail{font-size:12px;color:var(--dim);font-family:var(--font);white-space:pre-wrap;max-height:200px;overflow-y:auto;margin-top:6px}
.tool-toggle{font-size:12px;color:var(--accent);cursor:pointer;background:none;border:none;padding:2px 0}
.input-area{padding:16px 20px;border-top:1px solid var(--border);background:var(--panel);flex-shrink:0}
.input-wrap{display:flex;gap:10px;align-items:flex-end;background:var(--bg);border:1px solid var(--border);border-radius:14px;padding:10px 14px;transition:border-color .2s}
.input-wrap:focus-within{border-color:var(--accent)}
.input-wrap textarea{flex:1;background:none;border:none;color:var(--text);font-family:var(--font);font-size:14px;resize:none;outline:none;max-height:150px;line-height:1.5}
.send-btn{background:var(--accent);border:none;color:#fff;width:38px;height:38px;border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s}
.send-btn:hover{background:var(--accent);transform:scale(1.05);opacity:.9}
.send-btn:disabled{opacity:.4;cursor:default;transform:none}
.send-btn svg{width:18px;height:18px}
.interrupt-btn{background:#ff4444;border:none;color:#fff;width:38px;height:38px;border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s;font-size:14px;font-family:var(--font)}
.interrupt-btn:hover{background:#cc3333;transform:scale(1.05)}
.interrupt-btn:disabled{opacity:.3;cursor:default;transform:none}
.steer-btn{background:#00aa55;border:none;color:#fff;width:38px;height:38px;border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s;font-size:12px;font-family:var(--font)}
.steer-btn:hover{background:#008844;transform:scale(1.05)}
.steer-btn:disabled{opacity:.3;cursor:default;transform:none}
.server-start-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.7);z-index:200;display:none;align-items:center;justify-content:center}
.server-start-overlay.open{display:flex}
.server-start-box{background:var(--panel);border:1px solid var(--border);border-radius:16px;padding:24px;width:560px;max-height:70vh;display:flex;flex-direction:column;gap:12px}
.server-start-box h3{font-size:15px;color:var(--accent);margin:0;display:flex;align-items:center;gap:8px}
.server-start-log{flex:1;overflow-y:auto;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:12px;font-size:12px;font-family:var(--font);min-height:180px;max-height:320px;color:#aaa;white-space:pre-wrap;word-break:break-all}
.server-start-log .log-ready{color:var(--accent);font-weight:600}
.server-start-log .log-err{color:var(--error)}
.server-start-actions{display:flex;gap:8px;justify-content:flex-end}
.server-start-actions button{padding:8px 18px;border-radius:8px;border:1px solid var(--border);cursor:pointer;font-size:13px;font-family:var(--font);background:var(--bg);color:var(--text)}
.server-start-actions .btn-start{background:var(--accent);border-color:var(--accent);color:#000;font-weight:600}
.server-start-actions button:disabled{opacity:.4;cursor:default}
.thinking{display:flex;gap:4px;padding:4px 0}.thinking span{width:6px;height:6px;background:var(--accent);border-radius:50%;animation:bounce .6s infinite alternate}.thinking span:nth-child(2){animation-delay:.2s}.thinking span:nth-child(3){animation-delay:.4s}
@keyframes bounce{to{opacity:.3;transform:translateY(-4px)}}
@keyframes spin{to{transform:rotate(360deg)}}
.settings-panel{position:fixed;top:0;right:-380px;width:380px;height:100%;background:var(--panel);border-left:1px solid var(--border);z-index:100;transition:right .3s;padding:24px;overflow-y:auto}
.settings-panel.open{right:0}
.history-panel{position:fixed;top:0;left:-320px;width:320px;height:100%;background:var(--panel);border-right:1px solid var(--border);z-index:100;transition:left .3s;padding:24px;overflow-y:auto;display:flex;flex-direction:column}
.history-panel.open{left:0}
.history-panel h2{font-size:15px;color:var(--text);margin:0}
.hist-item{padding:12px;border:1px solid var(--border);border-radius:8px;margin-bottom:8px;cursor:pointer;background:var(--bg);transition:border-color .2s;position:relative}
.hist-item:hover{border-color:var(--accent)}
.hist-title{font-size:13px;font-weight:600;margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--text);padding-right:20px}
.hist-time{font-size:11px;color:var(--dim)}
.hist-del{position:absolute;top:8px;right:8px;z-index:2;background:none;border:none;color:var(--dim);cursor:pointer;opacity:0}
.hist-item:hover .hist-del{opacity:1}
.hist-del:hover{color:var(--error)}
.settings-panel h2{font-size:15px;margin-bottom:16px;color:var(--text)}
.settings-panel label{display:block;font-size:12px;color:var(--dim);margin:12px 0 4px;text-transform:uppercase;letter-spacing:.5px}
.settings-panel input,.settings-panel select{width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text);padding:10px 12px;border-radius:8px;font-size:13px;font-family:var(--font);outline:none;transition:border-color .2s}
.settings-panel input:focus,.settings-panel select:focus{border-color:var(--accent)}
.toggle-row{display:flex;align-items:center;justify-content:space-between;margin:16px 0}
.toggle-row span{font-size:13px}
.toggle{width:44px;height:24px;background:var(--border);border-radius:12px;position:relative;cursor:pointer;transition:background .2s}
.toggle.on{background:var(--accent)}
.toggle::after{content:'';position:absolute;top:3px;left:3px;width:18px;height:18px;background:#fff;border-radius:50%;transition:transform .2s}
.toggle.on::after{transform:translateX(20px)}
.settings-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.4);z-index:99;display:none}
.settings-overlay.open{display:block}
.diff-header{padding:12px 16px;border-bottom:1px solid var(--border);background:var(--panel);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.diff-header h3{font-size:13px;font-weight:500}
.diff-body{flex:1;overflow-y:auto;padding:12px;font-family:var(--font);font-size:12px;line-height:1.7}
.diff-section{margin-bottom:16px;border:1px solid var(--border);border-radius:8px;overflow:hidden}
.diff-file-header{padding:8px 12px;background:var(--panel);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;font-size:13px;font-weight:600}
.diff-filename{color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.diff-badge{font-size:10px;padding:2px 6px;border-radius:4px;font-weight:600;letter-spacing:.5px}
.diff-badge.write{background:#3ddc8422;color:#3ddc84;border:1px solid #3ddc8433}
.diff-badge.edit{background:#569cd622;color:#569cd6;border:1px solid #569cd633}
.diff-lines{font-size:12px;line-height:1.6}
.diff-row{display:flex;align-items:stretch}
.diff-row.add{background:rgba(61,220,132,0.08)}
.diff-row.rm{background:rgba(255,92,92,0.08)}
.diff-row.ctx{background:transparent}
.diff-row.ctx-fold{background:var(--bg);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.diff-gutter{width:40px;text-align:right;padding:0 8px;color:var(--dim);opacity:.5;flex-shrink:0;user-select:none;border-right:1px solid var(--border);font-size:11px;line-height:1.6}
.diff-sign{width:16px;text-align:center;flex-shrink:0;font-weight:700;padding:0 2px;line-height:1.6}
.diff-row.add .diff-sign{color:#3ddc84}
.diff-row.rm .diff-sign{color:#ff5c5c}
.diff-code{flex:1;padding:0 8px;white-space:pre;overflow-x:auto;font-family:var(--font);line-height:1.6;tab-size:4}
.diff-row.rm .diff-code{text-decoration:line-through;opacity:.7}
.diff-action-btn{font-family:var(--font);font-size:11px;padding:4px 10px;border-radius:6px;cursor:pointer;border:1px solid var(--border);transition:all .15s}
.diff-action-btn.undo{background:transparent;color:#ff5c5c;border-color:#ff5c5c33}
.diff-action-btn.undo:hover{background:#ff5c5c22;border-color:#ff5c5c}
.diff-action-btn.accept{background:var(--accent);color:#fff;border-color:var(--accent)}
.diff-action-btn.accept:hover{opacity:.9}
.welcome{text-align:center;padding:60px 40px;color:var(--dim);max-width:560px;margin:auto}
.welcome h2{font-size:22px;color:var(--text);margin-bottom:12px;font-weight:600}
.welcome p{font-size:14px;line-height:1.7;margin-bottom:8px}
.welcome .keys{display:flex;gap:10px;justify-content:center;margin-top:20px;flex-wrap:wrap}
.welcome .key{background:var(--panel);border:1px solid var(--border);padding:8px 16px;border-radius:10px;font-size:12px;color:var(--text);cursor:pointer;transition:all .15s}
.welcome .key:hover{border-color:var(--accent);color:var(--accent)}
.theme-toggle{background:none;border:1px solid var(--border);border-radius:4px;padding:4px 10px;cursor:pointer;color:var(--dim);font-family:var(--font);font-size:.7rem;letter-spacing:1px;transition:all .2s;text-transform:uppercase;margin-left:8px}
.theme-toggle:hover{border-color:var(--accent);color:var(--accent)}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs/loader.min.js"></script>
</head>
<body>
<div class="scanlines"></div>
<div class="grid-bg"></div>
<div class="app">
  <div class="sidebar">
    <div class="sidebar-header">📁 Explorer</div>
    <div class="sidebar-body" id="sidebar-tree"></div>
  </div>
  <div class="chat-col">
    <div class="header"><h1><span>Amni</span>-Code</h1><div class="cwd-info" id="cwd-info">📂 <span id="cwd-path">unknown</span></div><div class="header-actions">
        <button class="theme-toggle" id="theme-toggle" title="Toggle Theme">DARK</button>
        <button class="theme-cycle" id="theme-cycle" title="Cycle Accent Color">CODE</button>
        <button class="icon-btn" id="history-btn" title="Recent Chats">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </button>
        <button class="icon-btn" id="diff-toggle" title="Code Changes">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h7v18H3zM14 3h7v18h-7"/><path d="M7 8H5M7 12H5M7 16H5M19 8h-2M19 12h-2M19 16h-2"/></svg>
        </button>
        <button class="icon-btn" id="editor-toggle" title="Editor">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
        </button>
        <button class="icon-btn" id="new-chat" title="New Chat">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 7v6M9 10h6"/></svg>
        </button>
        <button class="icon-btn" id="settings-btn" title="Settings">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
        </button>
      </div>
    </div>
    <div class="messages" id="messages">
      <div class="welcome" id="welcome">
        <h2>Welcome to Amni-Code</h2>
        <p>Your AI coding agent. Type anything below &mdash; ask it to build features, fix bugs, create files, run commands, or explain code. It will do the work for you.</p>
        <p style="color:var(--text2);font-size:12px;margin-top:6px">Click &#9881; to configure your AI provider (xAI Grok by default)</p>
        <div class="keys">
          <div class="key" onclick="fillPrompt('Create a Python Flask API with user auth')">Build an API</div>
          <div class="key" onclick="fillPrompt('Find and fix the bug in main.py')">Debug code</div>
          <div class="key" onclick="fillPrompt('Explain how this codebase works')">Explain code</div>
          <div class="key" onclick="fillPrompt('Set up a new React project with TypeScript')">Scaffold project</div>
        </div>
      </div>
    </div>
    <div class="input-area">
      <div class="input-wrap">
        <textarea id="input" rows="1" placeholder="Ask Amni-Code to build, fix, or explain anything..."></textarea>
        <button class="interrupt-btn" id="interrupt" title="Stop generation" disabled>&#9632;</button>
        <button class="steer-btn" id="steer" title="Inject context mid-generation (type in input first)" disabled>&#9654;</button>
        <button class="send-btn" id="send" title="Send">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
        </button>
      </div>
    </div>
  </div>
  <div class="editor-col" id="editor-col">
    <div class="editor-header">
      <h3 id="editor-filename">untitled.py</h3>
        <div>
          <button class="icon-btn" onclick="requestAISuggestion()" title="AI Suggestion (Ctrl+Space)">✨</button>
          <button class="icon-btn" onclick="saveEditorFile()" title="Save to Workspace (Ctrl+S)">💾</button>
          <button class="icon-btn" onclick="toggleEditor()" title="Close">✕</button>
        </div>
    </div>
    <div class="tab-bar" id="tab-bar"></div>
    <div class="breadcrumbs" id="breadcrumbs"></div>
    <div class="editor-body" id="editor-body">
      <div id="monaco-container" style="width:100%;height:100%;"></div>
    </div>
  </div>
  <div class="diff-col" id="diff-col">
    <div class="diff-header">
      <h3>Code Changes</h3>
      <div style="display:flex;gap:6px;align-items:center">
        <button class="diff-action-btn undo" onclick="undoChanges()" title="Undo all changes">&#8617; Undo</button>
        <button class="diff-action-btn accept" onclick="acceptChanges()" title="Accept all changes">&#10003; Accept</button>
        <button class="icon-btn" onclick="toggleDiff()" title="Close">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
    </div>
    <div class="diff-body" id="diff-body"></div>
  </div>
</div>
<div class="settings-overlay" id="settings-overlay"></div>
<div class="history-panel" id="history-panel">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
    <h2>Recent Chats</h2>
    <span style="cursor:pointer;font-size:12px;color:var(--dim)" onclick="clearHistory()">Clear All</span>
  </div>
  <div id="history-list" style="flex:1;overflow-y:auto"></div>
</div>
<div class="server-start-overlay" id="server-start-overlay">
  <div class="server-start-box">
    <h3><span id="server-start-spinner" style="display:inline-block;animation:spin 1s linear infinite">&#9696;</span> Starting Inference Server</h3>
    <div style="font-size:12px;color:var(--dim)">Launching Amni-AI &mdash; this may take 15-30 seconds on first start.</div>
    <div class="server-start-log" id="server-start-log">Waiting to start...</div>
    <div class="server-start-actions">
      <button id="server-start-dismiss" onclick="closeServerPanel(false)">Dismiss</button>
      <button class="btn-start" id="server-start-btn" onclick="startServer()">Start Server</button>
    </div>
  </div>
</div>
<div class="settings-panel" id="settings-panel">
  <h2>Settings</h2>
  <label>Provider</label>
  <select id="cfg-provider">
    <option value="xai">xAI (Grok)</option>
    <option value="openai">OpenAI</option>
    <option value="anthropic">Anthropic</option>
    <option value="ollama">Ollama (Local)</option>
    <option value="local">Custom Local Server</option>
    <option value="amni">Amni-AI (Adam / Gemma PTEX)</option>
  </select>
  <label>Model</label>
  <select id="cfg-model"><option>Loading...</option></select>
  <label id="api-key-label">API Key <span style="font-size:10px;color:var(--green)" id="key-src"></span></label>
  <input id="cfg-key" type="password" placeholder="Not needed for Ollama">
  <label>Base URL</label>
  <input id="cfg-url" placeholder="http://localhost:11434">
  <label>Working Directory</label>
  <div style="display:flex;gap:6px;align-items:center;margin-bottom:4px">
    <input id="cfg-dir" placeholder="Current directory" style="flex:1;margin:0">
    <button onclick="navigateDirUp()" title="Up folder" style="padding:4px 10px;background:var(--surface2);border:1px solid var(--border);border-radius:4px;cursor:pointer;color:var(--text2);font-size:11px;flex-shrink:0;white-space:nowrap">↑ Up</button>
  </div>
  <div id="dir-tree" style="max-height:150px;overflow-y:auto;margin:6px 0;font-size:12px;font-family:var(--mono)"></div>
  <div id="model-dir-section" style="display:none">
    <label>Local Model Directory</label>
    <input id="cfg-model-dir" placeholder="e.g. C:\models or ~/models">
    <div style="margin-top:16px;border-top:1px solid var(--border);padding-top:16px">
      <label style="margin-top:0">Download Models from Hugging Face</label>
      <div style="display:flex;gap:6px;margin-top:6px">
        <input id="hf-search-input" placeholder="Search GGUF models..." style="flex:1">
        <button onclick="hfSearch()" style="background:var(--accent);border:none;color:#fff;padding:8px 14px;border-radius:8px;cursor:pointer;font-family:var(--font);font-size:12px;white-space:nowrap">Search</button>
      </div>
      <div id="hf-results" style="max-height:200px;overflow-y:auto;margin-top:8px;font-size:12px"></div>
      <div id="hf-files" style="max-height:200px;overflow-y:auto;margin-top:4px;font-size:12px"></div>
      <div id="hf-progress" style="display:none;margin-top:8px">
        <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--dim);margin-bottom:4px">
          <span id="hf-dl-name"></span>
          <span id="hf-dl-pct">0%</span>
        </div>
        <div style="height:6px;background:var(--border);border-radius:3px;overflow:hidden">
          <div id="hf-dl-bar" style="height:100%;background:var(--accent);width:0%;transition:width .3s"></div>
        </div>
        <div id="hf-dl-status" style="font-size:11px;color:var(--dim);margin-top:4px"></div>
      </div>
    </div>
  </div>
  <div class="toggle-row">
    <span>Auto-approve all agent actions</span>
    <div class="toggle" id="cfg-auto" onclick="this.classList.toggle('on')"></div>
  </div>
  <p style="font-size:11px;color:var(--text2);margin-top:8px">When off, you'll see what the agent wants to do before it executes. When on, it acts autonomously.</p>
</div>
<div class="qo-overlay" id="qo-overlay"></div>
<div class="qo-palette" id="qo-palette">
  <input id="qo-input" placeholder="Go to file..." autocomplete="off">
  <div class="qo-list" id="qo-list"></div>
</div>
<div class="toast-container" id="toast-container"></div>
<div class="status-bar" id="status-bar">
  <div class="status-left"><span class="status-item" id="sb-branch">main</span><span class="status-item" id="sb-errors">0 errors</span></div>
  <div class="status-right"><span class="status-item" id="sb-lang">Plaintext</span><span class="status-item" id="sb-pos">Ln 1, Col 1</span><span class="status-item">Amni-Code v2.1.0</span></div>
</div>
<div class="cmd-overlay" id="cmd-overlay"></div>
<div class="cmd-palette" id="cmd-palette">
  <input id="cmd-input" placeholder="Type a command..." autocomplete="off">
  <div class="cmd-list" id="cmd-list"></div>
</div>
<script>
const $ = s => document.querySelector(s);
const msgEl = $('#messages'), inputEl = $('#input'), sendBtn = $('#send'), interruptBtn = $('#interrupt'), steerBtn = $('#steer');
function setGenerating(on){ sendBtn.disabled = on; interruptBtn.disabled = !on; steerBtn.disabled = !on; }
let sessionId = null, diffData = [], currentChatId = null, sidebarBase = '';
let chatHistory = JSON.parse(localStorage.getItem('amniHistory') || '[]');

function saveCurrentChat(){
  if(!currentChatId) return;
  const idx = chatHistory.findIndex(c => c.id === currentChatId);
  const data = {
    id: currentChatId,
    title: chatHistory[idx]?.title || 'New Chat',
    date: Date.now(),
    html: msgEl.innerHTML,
    diff: diffData,
    sessionId: sessionId
  };
  if(idx >= 0) chatHistory[idx] = data;
  else chatHistory.unshift(data);
  localStorage.setItem('amniHistory', JSON.stringify(chatHistory));
}

function loadChat(id){
  const chat = chatHistory.find(c => c.id === id);
  if(!chat) return;
  currentChatId = chat.id;
  sessionId = chat.sessionId;
  diffData = chat.diff || [];
  msgEl.innerHTML = chat.html;
  msgEl.scrollTop = msgEl.scrollHeight;
  renderDiff();
  $('#history-panel').classList.remove('open');
  $('#settings-overlay').classList.remove('open');
}

function renderHistory(){
  const list = $('#history-list');
  if(!chatHistory.length){ list.innerHTML = '<p style="color:var(--dim);font-size:12px;text-align:center">No recent chats</p>'; return; }
  list.innerHTML = chatHistory.map(c => `
    <div class="hist-item" onclick="loadChat(${c.id})">
      <button class="hist-del" onclick="event.stopPropagation();deleteChat(${c.id})">&#10005;</button>
      <div class="hist-title">${escHtml(c.title)}</div>
      <div class="hist-time">${new Date(c.date).toLocaleString()}</div>
    </div>
  `).join('');
}

function deleteChat(id){
  chatHistory = chatHistory.filter(c => c.id !== id);
  localStorage.setItem('amniHistory', JSON.stringify(chatHistory));
  if(currentChatId === id) $('#new-chat').click();
  else renderHistory();
}

function clearHistory(){
  if(!confirm('Clear all chat history?')) return;
  chatHistory = [];
  localStorage.setItem('amniHistory', '[]');
  $('#new-chat').click();
  renderHistory();
}
function fillPrompt(t){ inputEl.value = t; inputEl.focus(); }
function autoResize(el){ el.style.height = 'auto'; el.style.height = Math.min(el.scrollHeight, 150) + 'px'; }
inputEl.addEventListener('input', () => autoResize(inputEl));
inputEl.addEventListener('keydown', e => { if(e.key === 'Enter' && !e.shiftKey){ e.preventDefault(); send(); }});
sendBtn.addEventListener('click', send);
$('#new-chat').addEventListener('click', () => { sessionId = null; diffData = []; currentChatId = null; msgEl.innerHTML = ''; location.reload(); });
$('#history-btn').addEventListener('click', () => { renderHistory(); $('#history-panel').classList.add('open'); $('#settings-overlay').classList.add('open'); });
$('#settings-btn').addEventListener('click', () => { $('#settings-panel').classList.toggle('open'); $('#settings-overlay').classList.toggle('open'); loadConfig(); });
$('#settings-overlay').addEventListener('click', () => { $('#settings-panel').classList.remove('open'); $('#history-panel').classList.remove('open'); $('#settings-overlay').classList.remove('open'); saveConfig(); });
$('#diff-toggle').addEventListener('click', toggleDiff);$('#theme-toggle').addEventListener('click', toggleTheme);function toggleDiff(){ $('#diff-col').classList.toggle('open'); $('#diff-toggle').classList.toggle('active'); }
function toggleTheme(){
  const body = document.body;
  const isLight = body.hasAttribute('data-theme') && body.getAttribute('data-theme') === 'light';
  if(isLight){
    body.removeAttribute('data-theme');
    $('#theme-toggle').textContent = 'DARK';
  } else {
    body.setAttribute('data-theme', 'light');
    $('#theme-toggle').textContent = 'LIGHT';
  }
  localStorage.setItem('theme', isLight ? 'dark' : 'light');
}
function escHtml(s){ const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
function escJsStr(s){ return s.replace(/\\/g, '\\\\').replace(/'/g, "\\'"); }
function renderMd(text){
  return text
    .replace(/```(\w*)\n([\s\S]*?)```/g, (_, lang, code) => `<pre><code>${escHtml(code.trim())}</code></pre>`)
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n/g, '<br>')
    .replace(/(https?:\/\/[^\s<"']+[^<.,:;"')\]\s])/g, '<a href="$1" target="_blank" rel="noopener" style="color:var(--accent);text-decoration:underline">$1</a>')
    .replace(/([^\s<"']+@[^\s<"']+\.[^\s<"']+)/g, '<a href="mailto:$1" style="color:var(--accent);text-decoration:underline">$1</a>');
}
function addMsg(role, content, tools){
  const w = $('#welcome'); if(w) w.remove();
  const div = document.createElement('div');
  div.className = `msg ${role}`;
  if(role === 'assistant' && tools && tools.length){
    let toolHtml = '<div class="tool-group">';
    tools.forEach(t => {
      const cls = t.status === 'success' ? 'success' : 'error';
      toolHtml += `<span class="tool-badge ${cls}">&#9889; ${escHtml(t.tool)}</span>`;
    });
    toolHtml += `<button class="tool-toggle" onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'block':'none'">&#9656; details</button>`;
    toolHtml += `<div class="tool-detail" style="display:none">`;
    tools.forEach(t => {
      if(t.tool === 'edit_file'){
        toolHtml += `<div style="margin:4px 0;color:var(--text2)">&#9472;&#9472; ${escHtml(t.tool)} &#8250; <strong>${escHtml(t.input.path||'')}</strong></div>`;
        const oldLines = (t.input.old_string||'').split('\n'), newLines = (t.input.new_string||'').split('\n');
        oldLines.forEach(l => { toolHtml += `<div style="color:#ff5c5c">- ${escHtml(l)}</div>`; });
        newLines.forEach(l => { toolHtml += `<div style="color:#3ddc84">+ ${escHtml(l)}</div>`; });
      } else if(t.tool === 'write_file'){
        toolHtml += `<div style="margin:4px 0;color:var(--text2)">&#9472;&#9472; ${escHtml(t.tool)} &#8250; <strong>${escHtml(t.input.path||'')}</strong></div>`;
        const lines = (t.input.content||'').split('\n').slice(0,30);
        lines.forEach(l => { toolHtml += `<div style="color:#3ddc84">+ ${escHtml(l)}</div>`; });
        if((t.input.content||'').split('\n').length > 30) toolHtml += `<div style="color:var(--dim)">... ${(t.input.content||'').split('\n').length - 30} more lines</div>`;
      } else {
        toolHtml += `<div style="margin:4px 0;color:var(--text2)">&#9472;&#9472; ${escHtml(t.tool)} &#9472;&#9472;</div>`;
        toolHtml += `<div>${escHtml(JSON.stringify(t.input,null,2).substring(0,300))}</div>`;
        if(t.output) toolHtml += `<div style="color:var(--dim)">${escHtml(t.output.substring(0,300))}${t.output.length>300?'...':''}</div>`;
      }
      if(t.tool === 'write_file' || t.tool === 'edit_file') parseDiff(t);
    });
    toolHtml += '</div></div>';
    div.innerHTML = toolHtml + renderMd(content);
  } else {
    div.innerHTML = role === 'user' ? escHtml(content) : renderMd(content);
  }
  msgEl.appendChild(div);
  msgEl.scrollTop = msgEl.scrollHeight;
  if(currentChatId) saveCurrentChat();
}
function parseDiff(tc){
  const entry = { file: tc.input.path || 'unknown', type: tc.tool };
  if(tc.tool === 'edit_file'){
    entry.removed = tc.input.old_string || '';
    entry.added = tc.input.new_string || '';
  } else if(tc.tool === 'write_file'){
    entry.removed = '';
    entry.added = tc.input.content || '';
  }
  diffData.push(entry);
  renderDiff();
  if(currentChatId) saveCurrentChat();
}
function renderDiffLine(text){
  if(!text && text !== '') return '&nbsp;';
  let s = escHtml(text);

  s = s
    .replace(/(\/\/.*|#[^{].*)/g,'<span style="color:#6a9955;font-style:italic">$1</span>')
    .replace(/(&quot;[^&]*?&quot;)/g,'<span style="color:#ce9178">$1</span>')
    .replace(/\b(function|const|let|var|return|if|else|for|while|import|from|class|def|async|await|fn|pub|use|struct|impl|match|self|true|false|null|None|undefined|mut|mod|enum|trait|type|where|loop|break|continue)\b/g,'<span style="color:#569cd6">$1</span>');
  return s || '&nbsp;';
}
function renderDiff(){
  const body = $('#diff-body');
  if(!diffData.length){ body.innerHTML = '<p style="color:var(--dim);padding:20px;text-align:center">No changes yet</p>'; return; }
  let html = '';
  diffData.forEach(d => {
    const ext = (d.file.split('.').pop()||'').toLowerCase();
    const icons = {js:'\ud83d\udcdc',ts:'\ud83d\udcdc',py:'\ud83d\udc0d',rs:'\ud83e\udd80',html:'\ud83c\udf10',css:'\ud83c\udfa8',json:'\ud83d\udccb'};
    const icon = icons[ext] || '\ud83d\udcc4';
    const badge = d.type === 'write_file' ? '<span class="diff-badge write">CREATE</span>' : '<span class="diff-badge edit">EDIT</span>';
    html += '<div class="diff-section">';
    html += '<div class="diff-file-header">' + icon + ' <span class="diff-filename">' + escHtml(d.file) + '</span> ' + badge + '</div>';
    html += '<div class="diff-lines">';
    if(d.type === 'write_file'){
      const lines = (d.added||'').split('\n');
      lines.forEach((line, i) => {
        html += '<div class="diff-row add"><span class="diff-gutter">' + (i+1) + '</span><span class="diff-sign">+</span><span class="diff-code">' + renderDiffLine(line) + '</span></div>';
      });
    } else {
      const oldL = d.removed ? d.removed.split('\n') : [];
      const newL = d.added ? d.added.split('\n') : [];
      let i = 0; while(i < oldL.length && i < newL.length && oldL[i] === newL[i]) i++;
      let j1 = oldL.length - 1, j2 = newL.length - 1;
      while(j1 >= i && j2 >= i && oldL[j1] === newL[j2]){ j1--; j2--; }
      const ctxPre = Math.max(0, i - 2);
      if(ctxPre > 0){
        html += '<div class="diff-row ctx-fold"><span class="diff-gutter">\u00b7\u00b7\u00b7</span><span class="diff-sign"> </span><span class="diff-code" style="color:var(--dim);font-style:italic">' + ctxPre + ' unchanged lines</span></div>';
      }
      for(let k=ctxPre; k<i; k++){
        if(oldL[k]!==undefined) html += '<div class="diff-row ctx"><span class="diff-gutter">' + (k+1) + '</span><span class="diff-sign"> </span><span class="diff-code">' + renderDiffLine(oldL[k]) + '</span></div>';
      }
      for(let k=i; k<=j1; k++){
        html += '<div class="diff-row rm"><span class="diff-gutter">' + (k+1) + '</span><span class="diff-sign">-</span><span class="diff-code">' + renderDiffLine(oldL[k]) + '</span></div>';
      }
      for(let k=i; k<=j2; k++){
        html += '<div class="diff-row add"><span class="diff-gutter">' + (k+1) + '</span><span class="diff-sign">+</span><span class="diff-code">' + renderDiffLine(newL[k]) + '</span></div>';
      }
      const ctxPost = Math.min(oldL.length - 1, j1 + 2);
      for(let k=j1+1; k<=ctxPost; k++){
        if(oldL[k]!==undefined) html += '<div class="diff-row ctx"><span class="diff-gutter">' + (k+1) + '</span><span class="diff-sign"> </span><span class="diff-code">' + renderDiffLine(oldL[k]) + '</span></div>';
      }
      if(j1 < oldL.length - 3){
        html += '<div class="diff-row ctx-fold"><span class="diff-gutter">\u00b7\u00b7\u00b7</span><span class="diff-sign"> </span><span class="diff-code" style="color:var(--dim);font-style:italic">' + (oldL.length - j1 - 3) + ' unchanged lines</span></div>';
      }
    }
    html += '</div></div>';
  });
  body.innerHTML = html;
  if(!$('#diff-col').classList.contains('open')) toggleDiff();
}
function showThinking(){
  const div = document.createElement('div');
  div.className = 'msg assistant';
  div.id = 'thinking';
  div.innerHTML = '<div class="thinking"><span></span><span></span><span></span></div>';
  msgEl.appendChild(div);
  msgEl.scrollTop = msgEl.scrollHeight;
}
function updateThinking(text){
  const el = $('#thinking');
  if(el) el.innerHTML = '<div style="display:flex;align-items:center;gap:8px"><div class="thinking"><span></span><span></span><span></span></div><span style="font-size:12px;color:var(--dim)">' + escHtml(text) + '</span></div>';
}
function removeThinking(){ const t = $('#thinking'); if(t) t.remove(); }
async function send(){
  const text = inputEl.value.trim();
  if(!text) return;
  if(!currentChatId){
    currentChatId = Date.now();
    chatHistory.unshift({ id: currentChatId, title: text.substring(0, 40) + '...', date: Date.now(), html: '', diff: [] });
  }
  inputEl.value = ''; autoResize(inputEl);
  setGenerating(true);
  addMsg('user', text);
  showThinking();
  try{
const res=await fetch('/api/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:text,session_id:sessionId,working_dir:$('#cfg-dir').value})});
    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';
    let allTools = [];
    let finalMessage = '';
    let gotMessage = false;
    while(true){
      const { value, done } = await reader.read();
      if(done) break;
      buffer += decoder.decode(value, { stream: true });
      while(buffer.includes('\n\n')){
        const idx = buffer.indexOf('\n\n');
        const chunk = buffer.substring(0, idx);
        buffer = buffer.substring(idx + 2);
        let eventType = '';
        let dataStr = '';
        for(const line of chunk.split('\n')){
          if(line.startsWith('event:')) eventType = line.substring(6).trim();
          else if(line.startsWith('data:')) dataStr += line.substring(5);
          else if(line.startsWith(':')) continue;
        }
        if(!dataStr) continue;
        try{
          const data = JSON.parse(dataStr);
          switch(eventType){
            case 'session':
              sessionId = data.session_id;
              break;
            case 'thinking':
              break;
            case 'tool_start':
              updateThinking(data.tool + '...');
              break;
            case 'tool_result':
              allTools.push(data);
              updateThinking(data.tool + ' done (' + allTools.length + ' actions)');
              if(data.tool === 'write_file' || data.tool === 'edit_file') parseDiff(data);
              break;
            case 'message':
              finalMessage = data.message;
              gotMessage = true;
              break;
            case 'error':
              removeThinking();
              addMsg('system', 'Error: ' + (data.error || 'Unknown'));
              setGenerating(false);
              inputEl.focus();
              return;
            case 'interrupted':
              removeThinking();
              addMsg('system', 'Generation interrupted.');
              setGenerating(false);
              inputEl.focus();
              return;
            case 'done':
              break;
          }
        } catch(e){ console.warn('SSE parse error:', e); }
      }
    }
    removeThinking();
    if(gotMessage || allTools.length){
      addMsg('assistant', finalMessage || '', allTools.length ? allTools : undefined);
    }
  } catch(e){
    removeThinking();
    addMsg('system', 'Connection error &mdash; is the server running? Check Settings for provider config.');
  }
  setGenerating(false);
  inputEl.focus();
}
async function undoChanges(){
  if(!sessionId || !diffData.length) return;
  if(!confirm('Undo all changes from this session?')) return;
  try{
    const res = await fetch('/api/undo', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ session_id: sessionId })
    });
    const data = await res.json();
    if(data.reverted && data.reverted.length){
      addMsg('system', 'Reverted ' + data.reverted.length + ' file(s)');
      diffData = [];
      renderDiff();
    } else {
      addMsg('system', 'No changes to undo');
    }
  } catch(e){ addMsg('system', 'Undo failed'); }
}
async function acceptChanges(){
  if(!sessionId || !diffData.length) return;
  try{
    await fetch('/api/accept', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ session_id: sessionId })
    });
    addMsg('system', 'Changes accepted');
    diffData = [];
    renderDiff();
  } catch(e){}
}
async function interruptGen(){
  if(!sessionId) return;
  try{
    await fetch('/api/interrupt', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({session_id:sessionId})});
  } catch(e){}
}
async function steerGen(){
  const text = inputEl.value.trim();
  if(!text || !sessionId) return;
  inputEl.value = ''; autoResize(inputEl);
  try{
    const res = await fetch('/api/steer', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({session_id:sessionId,message:text})});
    const data = await res.json();
    data.status === 'steered' ? addMsg('user', '[STEER: ' + text + ']') : addMsg('system', 'Steer failed');
  } catch(e){ addMsg('system', 'Steer failed'); }
}
async function loadConfig(){
  try{
    const res = await fetch('/api/config');
    const c = await res.json();
    $('#cfg-provider').value = c.provider;
    $('#cfg-key').value = c.api_key;
    $('#cfg-url').value = c.base_url;
$('#cfg-dir').value=c.working_dir;$('#cwd-path').textContent=c.working_dir||'unknown';if(c.model_dir)$('#cfg-model-dir').value=c.model_dir;if(c.auto_approve)$('#cfg-auto').classList.add('on');else $('#cfg-auto').classList.remove('on');if(c.api_key)$('#key-src').textContent='(from ENV)';$('#model-dir-section').style.display=(c.provider==='ollama'||c.provider==='local')?'block':'none';$('#api-key-label').style.display=(c.provider==='ollama'||c.provider==='local')?'none':'block';$('#cfg-key').style.display=(c.provider==='ollama'||c.provider==='local')?'none':'block';await loadModels(c.model);loadDirs(c.working_dir);loadSidebar(c.working_dir);
  } catch(e){console.error('loadConfig:',e);}
}
async function loadModels(current){
  try{
    const res = await fetch('/api/models');
    const data = await res.json();
    const sel = $('#cfg-model');
    sel.innerHTML = '';
    if(data.models.length === 0){
      const p = $('#cfg-provider').value;
      if((p === 'amni' || p === 'local') && !$('#server-start-overlay').classList.contains('open')){
        sel.innerHTML = '<option>(starting server...)</option>';
        checkAndStartServer();
        return;
      }
      const hint = p === 'ollama' ? '(no models &mdash; run: ollama pull <model>)' : p === 'amni' ? '(no models &mdash; is Amni-AI running on :8787?)' : '(no models found)';
      sel.innerHTML = `<option>${hint}</option>`;
      return;
    }
    data.models.forEach(m => {
      const opt = document.createElement('option');
      opt.value = m; opt.textContent = m;
      sel.appendChild(opt);
    });
    if(current && data.models.includes(current)){
      sel.value = current;
    } else if(current && !current.startsWith('(')){
      const opt = document.createElement('option');
      opt.value = current; opt.textContent = current + ' (custom)';
      sel.insertBefore(opt, sel.firstChild);
      sel.value = current;
    } else {
      // No valid saved model — select first from list and persist it
      sel.value = data.models[0];
      saveConfig();
    }
  } catch(e){ $('#cfg-model').innerHTML = '<option>Error loading</option>'; }
}
$('#cfg-model').addEventListener('change', () => saveConfig());
async function loadDirs(base){
  try{
    const res = await fetch('/api/dirs?path=' + encodeURIComponent(base || ''));
    const data = await res.json();
    const tree = $('#dir-tree');
    if(!data.dirs.length){ tree.innerHTML = '<span style="color:var(--dim)">No subdirectories</span>'; return; }
    tree.innerHTML = data.dirs.map(d =>
      `<div style="padding:2px 6px;cursor:pointer;border-radius:4px;color:var(--text2)" 
        onmouseenter="this.style.background='var(--surface2)';this.style.color='var(--accent)'" 
        onmouseleave="this.style.background='';this.style.color='var(--text2)'"
          onclick="selectDir(this, decodeURIComponent('${encodeURIComponent(base)}'), decodeURIComponent('${encodeURIComponent(d)}'))">&#128193; ${escHtml(d)}</div>`
    ).join('');
  } catch(e){}
}
function selectDir(el, base, name){
  const full = base.replace(/[/\\]$/, '') + (base.includes('/') ? '/' : '\\') + name;
  $('#cfg-dir').value = full;
  loadDirs(full);
  loadSidebar(full);
}
function navigateDirUp(){
  const cur = ($('#cfg-dir').value || '').replace(/[/\\]+$/, '');
  if(!cur) return;
  const sep = cur.includes('/') ? '/' : '\\';
  const parts = cur.split(/[/\\]/);
  if(parts.length <= 1) return;
  parts.pop();
  const parent = parts.join(sep) || sep;
  $('#cfg-dir').value = parent;
  loadDirs(parent);
  loadSidebar(parent);
  saveConfig();
}
async function loadSidebar(base){
  sidebarBase = base || '';
  const tree = $('#sidebar-tree');
  if(!tree) return;
  try{
    const res = await fetch('/api/ls?path=' + encodeURIComponent(base || ''));
    const data = await res.json();
    const sep = (base||'').includes('/') ? '/' : '\\';
    const clean = (base||'').replace(/[/\\]+$/, '');
    const parts = clean.split(/[/\\]/);
    let html = `<div class="sb-path">${escHtml(base||'')}</div>`;
    if(parts.length > 1 && clean){ const parent = parts.slice(0,-1).join(sep)||sep; html += `<div class="sb-item sb-up" data-path="${encodeURIComponent(parent)}">↑ ..</div>`; }
    data.dirs.forEach(d => { html += `<div class="sb-item sb-dir" data-path="${encodeURIComponent(clean+sep+d)}">📁 ${escHtml(d)}</div>`; });
    data.files.forEach(f => { html += `<div class="sb-item sb-file" data-path="${encodeURIComponent(clean+sep+f)}">${escHtml(f)}</div>`; });
    tree.innerHTML = html;
    tree.querySelectorAll('.sb-dir,.sb-up').forEach(el => el.addEventListener('click', () => loadSidebar(decodeURIComponent(el.dataset.path))));
    tree.querySelectorAll('.sb-file').forEach(el => el.addEventListener('click', () => openSidebarFile(decodeURIComponent(el.dataset.path))));
  } catch(e){ tree.innerHTML = '<span style="color:var(--dim)">Error</span>'; }
}
async function openSidebarFile(path){
  try{
    const res = await fetch('/api/read_file?path=' + encodeURIComponent(path));
    const data = await res.json();
    loadFileToEditor(path, data.content);
    if(!monacoEditor) toggleEditor();
  } catch(e){ addMsg('system', 'Could not open: ' + path); }
}
async function saveConfig(){
  try{
    const rawModel = $('#cfg-model').value;
    // Don't persist placeholder values as the model name
    const placeholders = ['Loading...', '(starting server...)', '(no models found)', 'Error loading'];
    const model = placeholders.some(p => rawModel.startsWith(p)) ? '' : rawModel;
    await fetch('/api/config', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        provider: $('#cfg-provider').value,
        model,
        api_key: $('#cfg-key').value,
        base_url: $('#cfg-url').value,
        working_dir: $('#cfg-dir').value,
        model_dir: $('#cfg-model-dir').value,
        auto_approve: $('#cfg-auto').classList.contains('on')
      })
    });
  } catch(e){}
}
let _serverLogEs = null;
function openServerPanel(){ $('#server-start-overlay').classList.add('open'); }
function closeServerPanel(andReload){ $('#server-start-overlay').classList.remove('open'); if(_serverLogEs){ _serverLogEs.close(); _serverLogEs=null; } if(andReload) loadModels($('#cfg-model').value); }
function appendServerLog(text, cls){
  const log = $('#server-start-log');
  const line = document.createElement('div');
  if(cls) line.className = cls;
  line.textContent = text;
  log.appendChild(line);
  log.scrollTop = log.scrollHeight;
}
async function startServer(){
  const btn = $('#server-start-btn');
  btn.disabled = true;
  $('#server-start-log').innerHTML = '';
  appendServerLog('Requesting server start...');
  try{
    const res = await fetch('/api/server-start', {method:'POST', headers:{'Content-Type':'application/json'}, body:'{}'});
    const data = await res.json();
    if(data.status === 'already_running'){ appendServerLog('Server is already running.', 'log-ready'); setTimeout(()=>closeServerPanel(true), 1200); return; }
    if(data.status === 'already_starting'){ appendServerLog('Server is already starting — watching logs...'); }
    else if(data.status === 'error'){ appendServerLog('Error: ' + data.message, 'log-err'); btn.disabled = false; return; }
    else if(data.status === 'starting'){ appendServerLog('Launched: ' + (data.dir||''), 'log-ready'); }
    // Subscribe to log stream
    if(_serverLogEs) _serverLogEs.close();
    _serverLogEs = new EventSource('/api/server-log');
    _serverLogEs.onmessage = e => appendServerLog(e.data, e.data.startsWith('[err]') ? 'log-err' : '');
    _serverLogEs.addEventListener('ready', () => {
      appendServerLog('Server is ready!', 'log-ready');
      $('#server-start-spinner').style.animation = 'none';
      setTimeout(()=>closeServerPanel(true), 1500);
    });
    _serverLogEs.addEventListener('timeout', () => { appendServerLog('Server failed to start after 3 minutes.', 'log-err'); btn.disabled = false; });
    _serverLogEs.onerror = () => {};
  } catch(e){ appendServerLog('Request failed: ' + e, 'log-err'); btn.disabled = false; }
}
async function checkAndStartServer(){
  try{
    const res = await fetch('/api/server-status');
    const data = await res.json();
    if(!data.applicable || data.running){
      // Already running (or not a local provider) — just populate the model list
      loadModels();
      return;
    }
    // Server offline — open panel and start it
    openServerPanel();
    await startServer(); // on ready, startServer calls closeServerPanel(true) → loadModels
  } catch(e){ loadModels(); }
}
$('#cfg-provider').addEventListener('change', () => {
  const p = $('#cfg-provider').value;
  if(p === 'ollama'){ $('#cfg-url').value = 'http://localhost:11434'; }
  else if(p === 'local'){ $('#cfg-url').value = 'http://localhost:8787'; }
  else if(p === 'amni'){ $('#cfg-url').value = 'http://127.0.0.1:8787'; }
  else if(p === 'openai'){ $('#cfg-url').value = 'https://api.openai.com'; }
  else if(p === 'anthropic'){ $('#cfg-url').value = 'https://api.anthropic.com'; }
  else if(p === 'xai'){ $('#cfg-url').value = 'https://api.x.ai'; }
  const isLocal = p === 'ollama' || p === 'local' || p === 'amni';
  $('#model-dir-section').style.display = (p === 'ollama' || p === 'local') ? 'block' : 'none';
  $('#api-key-label').style.display = isLocal ? 'none' : 'block';
  $('#cfg-key').style.display = isLocal ? 'none' : 'block';
  // Clear stale model from previous provider before saving
  $('#cfg-model').innerHTML = '<option>Loading...</option>';
  saveConfig().then(() => {
    if(p === 'amni' || p === 'local') checkAndStartServer();
    else loadModels();
  });
});
$('#cfg-url').addEventListener('change', () => { saveConfig().then(() => loadModels()); });
$('#cfg-model-dir').addEventListener('change', () => { saveConfig().then(() => loadModels()); });
$('#cfg-dir').addEventListener('change', () => { saveConfig(); loadDirs($('#cfg-dir').value); loadSidebar($('#cfg-dir').value); });
$('#hf-search-input').addEventListener('keydown', e => { if(e.key === 'Enter'){ e.preventDefault(); hfSearch(); }});
let hfPollInterval = null;
function fmtSize(b){
  if(b >= 1073741824) return (b/1073741824).toFixed(1) + ' GB';
  if(b >= 1048576) return (b/1048576).toFixed(0) + ' MB';
  if(b >= 1024) return (b/1024).toFixed(0) + ' KB';
  return b + ' B';
}
async function hfSearch(){
  const q = $('#hf-search-input').value.trim();
  if(!q) return;
  const el = $('#hf-results');
  el.innerHTML = '<span style="color:var(--dim)">Searching...</span>';
  $('#hf-files').innerHTML = '';
  try{
    const res = await fetch('/api/hf/search?q=' + encodeURIComponent(q));
    const data = await res.json();
    if(!data.length){ el.innerHTML = '<span style="color:var(--dim)">No GGUF models found</span>'; return; }
    el.innerHTML = data.map(m => {
      const dl = m.downloads >= 1000 ? (m.downloads/1000).toFixed(0) + 'k' : m.downloads;
      return `<div style="padding:6px 8px;cursor:pointer;border:1px solid var(--border);border-radius:6px;margin-bottom:4px;transition:border-color .2s"
        onmouseenter="this.style.borderColor='var(--accent)'"
        onmouseleave="this.style.borderColor='var(--border)'"
        onclick="hfShowFiles('${escJsStr(m.id)}',this)">
        <div style="font-weight:600;color:var(--text)">${escHtml(m.id)}</div>
        <div style="color:var(--dim);font-size:11px">&#11015; ${dl} downloads &middot; &hearts; ${m.likes}</div>
      </div>`;
    }).join('');
  } catch(e){ el.innerHTML = '<span style="color:var(--error)">Search failed</span>'; }
}
async function hfShowFiles(repo, el){
  const filesEl = $('#hf-files');
  filesEl.innerHTML = '<span style="color:var(--dim)">Loading files...</span>';
  try{
    const res = await fetch('/api/hf/files?repo=' + encodeURIComponent(repo));
    const files = await res.json();
    if(!files.length){ filesEl.innerHTML = '<span style="color:var(--dim)">No GGUF files in this repo</span>'; return; }
    filesEl.innerHTML = '<div style="color:var(--accent);font-weight:600;margin-bottom:6px;font-size:11px">GGUF FILES &mdash; ' + escHtml(repo) + '</div>' +
      files.map(f => `<div style="display:flex;align-items:center;justify-content:space-between;padding:4px 8px;border:1px solid var(--border);border-radius:6px;margin-bottom:3px">
        <div style="flex:1;min-width:0">
          <div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="${escHtml(f.name)}">${escHtml(f.name)}</div>
          <div style="color:var(--dim);font-size:10px">${fmtSize(f.size)}</div>
        </div>
        <button onclick="hfDownload('${escJsStr(repo)}','${escJsStr(f.name)}')" style="background:var(--accent);border:none;color:#fff;padding:4px 10px;border-radius:6px;cursor:pointer;font-family:var(--font);font-size:11px;flex-shrink:0;margin-left:8px">Download</button>
      </div>`).join('');
  } catch(e){ filesEl.innerHTML = '<span style="color:var(--error)">Failed to load files</span>'; }
}
async function hfDownload(repo, file){
  const progEl = $('#hf-progress');
  progEl.style.display = 'block';
  $('#hf-dl-name').textContent = file;
  $('#hf-dl-pct').textContent = '0%';
  $('#hf-dl-bar').style.width = '0%';
  $('#hf-dl-status').textContent = 'Starting download...';
  try{
    const res = await fetch('/api/hf/download', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ repo, file })
    });
    const data = await res.json();
    if(data.status === 'exists'){
      $('#hf-dl-status').textContent = 'Already downloaded: ' + data.path;
      $('#hf-dl-bar').style.width = '100%';
      $('#hf-dl-pct').textContent = '100%';
      return;
    }
    if(data.status === 'busy'){
      $('#hf-dl-status').textContent = data.message;
      return;
    }
    $('#hf-dl-status').textContent = 'Downloading to ' + data.path;
    if(hfPollInterval) clearInterval(hfPollInterval);
    hfPollInterval = setInterval(hfPollProgress, 1000);
  } catch(e){ $('#hf-dl-status').textContent = 'Failed to start download'; }
}
async function hfPollProgress(){
  try{
    const res = await fetch('/api/hf/progress');
    const p = await res.json();
    if(p.total > 0){
      const pct = Math.round((p.downloaded / p.total) * 100);
      $('#hf-dl-bar').style.width = pct + '%';
      $('#hf-dl-pct').textContent = pct + '%';
      $('#hf-dl-status').textContent = fmtSize(p.downloaded) + ' / ' + fmtSize(p.total);
    }
    if(p.done){
      clearInterval(hfPollInterval);
      hfPollInterval = null;
      if(p.error){
        $('#hf-dl-status').textContent = 'Error: ' + p.error;
        $('#hf-dl-status').style.color = 'var(--error)';
      } else {
        $('#hf-dl-bar').style.width = '100%';
        $('#hf-dl-pct').textContent = '100%';
        $('#hf-dl-status').textContent = 'Download complete! Refreshing models...';
        $('#hf-dl-status').style.color = 'var(--accent)';
        setTimeout(() => loadModels(), 1000);
      }
    }
  } catch(e){}
}
loadConfig();
const savedTheme = localStorage.getItem('theme');
if(savedTheme === 'light'){
  document.body.setAttribute('data-theme', 'light');
  $('#theme-toggle').textContent = 'LIGHT';
}
const savedAccent = localStorage.getItem('accentTheme');
if(savedAccent){
  document.body.className = document.body.className.replace(/theme-\S+/g, '');
  if(savedAccent !== 'code') document.body.classList.add('theme-' + savedAccent);
  $('#theme-cycle').textContent = savedAccent.toUpperCase();
}

// Toast notifications
function showToast(msg, duration) {
  duration = duration || 3000;
  const el = document.createElement('div');
  el.className = 'toast';
  el.textContent = msg;
  $('#toast-container').appendChild(el);
  setTimeout(() => { el.classList.add('fade-out'); setTimeout(() => el.remove(), 250); }, duration);
}

// Accent Theme Cycling
const accentThemes = ['code','crypt','haven','ai','core','explore','calc','green'];
let currentAccentIdx = accentThemes.indexOf(savedAccent || 'code');
if (currentAccentIdx < 0) currentAccentIdx = 0;
$('#theme-cycle').addEventListener('click', () => {
  currentAccentIdx = (currentAccentIdx + 1) % accentThemes.length;
  const t = accentThemes[currentAccentIdx];
  document.body.className = document.body.className.replace(/theme-\S+/g, '');
  if(t !== 'code') document.body.classList.add('theme-' + t);
  $('#theme-cycle').textContent = t.toUpperCase();
  localStorage.setItem('accentTheme', t);
  showToast('Accent: ' + t.charAt(0).toUpperCase() + t.slice(1));
});

// Monaco Editor with Multi-Tab Support
let monacoEditor = null;
let currentEditorFile = null;
let openTabs = []; // [{path, model, viewState}]
let activeTabIdx = -1;

function toggleEditor() {
  const col = $('#editor-col');
  col.classList.toggle('open');
  const toggleBtn = $('#editor-toggle');
  if (col.classList.contains('open')) {
    toggleBtn.classList.add('active');
    if (!monacoEditor) setTimeout(initMonacoEditor, 300);
  } else {
    toggleBtn.classList.remove('active');
  }
}

function initMonacoEditor() {
  if (monacoEditor) return;
  require.config({ paths: { vs: 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs' } });
  window.require(['vs/editor/editor.main'], () => {
    monacoEditor = monaco.editor.create($('#monaco-container'), {
      value: '',
      language: 'plaintext',
      theme: document.body.hasAttribute('data-theme') && document.body.getAttribute('data-theme') === 'light' ? 'vs' : 'vs-dark',
      automaticLayout: true,
      fontSize: 14,
      minimap: { enabled: false },
      scrollBeyondLastLine: false
    });
    monacoEditor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyCode.KeyS, () => saveEditorFile());
    monacoEditor.addCommand(monaco.KeyMod.CtrlCmd | monaco.KeyCode.Space, () => requestAISuggestion());
    monacoEditor.onDidChangeCursorPosition(() => updateStatusBar());
    if (openTabs.length > 0) switchTab(activeTabIdx >= 0 ? activeTabIdx : 0);
  });
}

function getLanguage(fn) {
  const ext = fn.split('.').pop().toLowerCase();
  const map = {py:'python',js:'javascript',ts:'typescript',jsx:'javascriptreact',tsx:'typescriptreact',rs:'rust',html:'html',css:'css',json:'json',md:'markdown',sh:'bash',bat:'bat',toml:'ini',yaml:'yaml',yml:'yaml',xml:'xml',sql:'sql',c:'c',cpp:'cpp',h:'c',hpp:'cpp',java:'java',go:'go',rb:'ruby',php:'php',swift:'swift',kt:'kotlin',r:'r',lua:'lua',zig:'zig'};
  return map[ext] || 'plaintext';
}

function renderTabs() {
  const bar = $('#tab-bar');
  if (!bar) return;
  bar.innerHTML = openTabs.map((t, i) => {
    const name = t.path.split(/[/\\]/).pop();
    return `<div class="tab${i === activeTabIdx ? ' active' : ''}" onclick="switchTab(${i})" title="${escHtml(t.path)}"><span>${escHtml(name)}</span><span class="tab-close" onclick="event.stopPropagation();closeTab(${i})">✕</span></div>`;
  }).join('');
}

function openTab(path, content) {
  const existing = openTabs.findIndex(t => t.path === path);
  if (existing >= 0) { switchTab(existing); return; }
  const lang = getLanguage(path);
  let mdl = null;
  if (monacoEditor) {
    const uri = monaco.Uri.parse('file:///' + path.replace(/\\/g, '/'));
    mdl = monaco.editor.getModel(uri) || monaco.editor.createModel(content || '', lang, uri);
  }
  openTabs.push({ path, model: mdl, viewState: null });
  activeTabIdx = openTabs.length - 1;
  if (monacoEditor && mdl) monacoEditor.setModel(mdl);
  currentEditorFile = path;
  $('#editor-filename').textContent = path.split(/[/\\]/).pop();
  updateBreadcrumbs(path);
  renderTabs();
}

function switchTab(idx) {
  if (idx < 0 || idx >= openTabs.length) return;
  if (activeTabIdx >= 0 && activeTabIdx < openTabs.length && monacoEditor) {
    openTabs[activeTabIdx].viewState = monacoEditor.saveViewState();
  }
  activeTabIdx = idx;
  const tab = openTabs[idx];
  currentEditorFile = tab.path;
  $('#editor-filename').textContent = tab.path.split(/[/\\]/).pop();
  if (monacoEditor) {
    if (tab.model) monacoEditor.setModel(tab.model);
    if (tab.viewState) monacoEditor.restoreViewState(tab.viewState);
    monacoEditor.focus();
    updateStatusBar();
  }
  updateBreadcrumbs(tab.path);
  renderTabs();
}

function closeTab(idx) {
  if (idx < 0 || idx >= openTabs.length) return;
  const tab = openTabs[idx];
  if (tab.model && !tab.model.isDisposed()) tab.model.dispose();
  openTabs.splice(idx, 1);
  if (openTabs.length === 0) {
    activeTabIdx = -1;
    currentEditorFile = null;
    $('#editor-filename').textContent = 'untitled.py';
    if (monacoEditor) monacoEditor.setModel(monaco.editor.createModel('', 'plaintext'));
  } else {
    activeTabIdx = Math.min(idx, openTabs.length - 1);
    switchTab(activeTabIdx);
  }
  renderTabs();
}

function loadFileToEditor(filename, content) {
  currentEditorFile = filename;
  $('#editor-filename').textContent = filename.split(/[/\\]/).pop();
  if (monacoEditor) {
    openTab(filename, content);
  } else {
    openTabs.push({ path: filename, model: null, viewState: null });
    activeTabIdx = openTabs.length - 1;
    toggleEditor();
    const waitForMonaco = setInterval(() => {
      if (monacoEditor) {
        clearInterval(waitForMonaco);
        const lang = getLanguage(filename);
        const uri = monaco.Uri.parse('file:///' + filename.replace(/\\/g, '/'));
        const mdl = monaco.editor.getModel(uri) || monaco.editor.createModel(content || '', lang, uri);
        openTabs[activeTabIdx].model = mdl;
        monacoEditor.setModel(mdl);
        renderTabs();
      }
    }, 100);
  }
}

async function saveEditorFile() {
  if (!monacoEditor || !currentEditorFile) {
    alert('Open a file first!');
    return;
  }
  const content = monacoEditor.getValue();
  try {
    await fetch('/api/write_file', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({path: currentEditorFile, content: content})
    });
    addMsg('system', `Saved ${currentEditorFile} from editor!`);
    showToast('Saved ' + currentEditorFile.split(/[/\\]/).pop());
  } catch(e) {
    addMsg('system', 'Save failed - check connection.');
  }
}

function requestAISuggestion() {
  if (!monacoEditor || !currentEditorFile) return;
  const content = monacoEditor.getValue();
  const cursor = monacoEditor.getPosition();
  const prompt = `AI suggestion/completion for ${currentEditorFile} around line ${cursor.lineNumber}:\n\`\`\`\n${content}\n\`\`\`\n`;
  $('#input').value = prompt;
  $('#send').click();
  toggleEditor(); // Maybe hide editor so they can see chat, or stay open? Let's leave open
}

$('#interrupt').addEventListener('click', interruptGen);
$('#steer').addEventListener('click', steerGen);
$('#editor-toggle').addEventListener('click', toggleEditor);

// Command Palette
const cmdCommands = [
  { label: 'New Chat', key: '', fn: () => $('#new-chat').click() },
  { label: 'Toggle Editor', key: 'Ctrl+E', fn: toggleEditor },
  { label: 'Toggle Diff Panel', key: '', fn: toggleDiff },
  { label: 'Save File', key: 'Ctrl+S', fn: saveEditorFile },
  { label: 'Quick Open File', key: 'Ctrl+P', fn: openQuickOpen },
  { label: 'Toggle Settings', key: '', fn: () => $('#settings-btn').click() },
  { label: 'Toggle Theme', key: '', fn: toggleTheme },
  { label: 'Cycle Accent Color', key: '', fn: () => $('#theme-cycle').click() },
  { label: 'Chat History', key: '', fn: () => $('#history-btn').click() },
  { label: 'AI Suggestion', key: 'Ctrl+Space', fn: requestAISuggestion },
  { label: 'Close Active Tab', key: '', fn: () => { if (activeTabIdx >= 0) closeTab(activeTabIdx); } },
  { label: 'Next Tab', key: '', fn: () => { if (openTabs.length > 1) switchTab((activeTabIdx + 1) % openTabs.length); } },
  { label: 'Previous Tab', key: '', fn: () => { if (openTabs.length > 1) switchTab((activeTabIdx - 1 + openTabs.length) % openTabs.length); } },
  { label: 'Focus Chat Input', key: '', fn: () => inputEl.focus() },
  { label: 'Undo Changes', key: '', fn: undoChanges },
  { label: 'Accept Changes', key: '', fn: acceptChanges },
];
let cmdSelectedIdx = 0;
function openCmdPalette() {
  $('#cmd-overlay').classList.add('open');
  $('#cmd-palette').classList.add('open');
  const inp = $('#cmd-input');
  inp.value = '';
  cmdSelectedIdx = 0;
  renderCmdList('');
  setTimeout(() => inp.focus(), 50);
}
function closeCmdPalette() {
  $('#cmd-overlay').classList.remove('open');
  $('#cmd-palette').classList.remove('open');
}
function renderCmdList(query) {
  const q = query.toLowerCase();
  const filtered = q ? cmdCommands.filter(c => c.label.toLowerCase().includes(q)) : cmdCommands;
  cmdSelectedIdx = Math.min(cmdSelectedIdx, Math.max(filtered.length - 1, 0));
  $('#cmd-list').innerHTML = filtered.map((c, i) =>
    `<div class="cmd-item${i === cmdSelectedIdx ? ' selected' : ''}" data-idx="${i}"><span>${escHtml(c.label)}</span>${c.key ? '<span class="cmd-key">' + c.key + '</span>' : ''}</div>`
  ).join('');
  $('#cmd-list').querySelectorAll('.cmd-item').forEach((el, i) => {
    el.addEventListener('click', () => { closeCmdPalette(); filtered[i].fn(); });
    el.addEventListener('mouseenter', () => { cmdSelectedIdx = i; renderCmdList(query); });
  });
}
$('#cmd-input').addEventListener('input', e => { cmdSelectedIdx = 0; renderCmdList(e.target.value); });
$('#cmd-input').addEventListener('keydown', e => {
  const q = e.target.value.toLowerCase();
  const filtered = q ? cmdCommands.filter(c => c.label.toLowerCase().includes(q)) : cmdCommands;
  if (e.key === 'ArrowDown') { e.preventDefault(); cmdSelectedIdx = Math.min(cmdSelectedIdx + 1, filtered.length - 1); renderCmdList(e.target.value); }
  else if (e.key === 'ArrowUp') { e.preventDefault(); cmdSelectedIdx = Math.max(cmdSelectedIdx - 1, 0); renderCmdList(e.target.value); }
  else if (e.key === 'Enter' && filtered.length > 0) { e.preventDefault(); closeCmdPalette(); filtered[cmdSelectedIdx].fn(); }
  else if (e.key === 'Escape') { closeCmdPalette(); }
});
$('#cmd-overlay').addEventListener('click', closeCmdPalette);

// File Watcher Events (auto-refresh sidebar)
try {
  const fsEvents = new EventSource('/api/fs-events');
  fsEvents.addEventListener('fs', () => { if (sidebarBase) loadSidebar(sidebarBase); });
} catch(e) {}

// Status bar cursor tracking
function updateStatusBar() {
  if (!monacoEditor) return;
  const pos = monacoEditor.getPosition();
  if (pos) $('#sb-pos').textContent = 'Ln ' + pos.lineNumber + ', Col ' + pos.column;
  if (currentEditorFile) {
    const lang = getLanguage(currentEditorFile);
    $('#sb-lang').textContent = lang.charAt(0).toUpperCase() + lang.slice(1);
  }
}

// Breadcrumbs
function updateBreadcrumbs(path) {
  const bc = $('#breadcrumbs');
  if (!bc || !path) { if(bc) bc.innerHTML = ''; return; }
  const parts = path.split(/[/\\]/).filter(Boolean);
  bc.innerHTML = parts.map((p, i) => {
    const isLast = i === parts.length - 1;
    return (i > 0 ? '<span class="bc-sep">›</span>' : '') + '<span' + (isLast ? ' style="color:var(--accent)"' : '') + '>' + escHtml(p) + '</span>';
  }).join('');
}

// Quick Open (Ctrl+P)
let qoFiles = [];
let qoSelectedIdx = 0;
async function loadQoFiles() {
  try {
    const res = await fetch('/api/ls?path=' + encodeURIComponent(sidebarBase || ''));
    const data = await res.json();
    const base = (sidebarBase || '').replace(/[/\\]+$/, '');
    const sep = base.includes('/') ? '/' : '\\';
    qoFiles = data.files.map(f => ({ name: f, path: base + sep + f }));
  } catch(e) { qoFiles = []; }
}
function openQuickOpen() {
  loadQoFiles().then(() => {
    $('#qo-overlay').classList.add('open');
    $('#qo-palette').classList.add('open');
    const inp = $('#qo-input');
    inp.value = '';
    qoSelectedIdx = 0;
    renderQoList('');
    setTimeout(() => inp.focus(), 50);
  });
}
function closeQuickOpen() {
  $('#qo-overlay').classList.remove('open');
  $('#qo-palette').classList.remove('open');
}
function renderQoList(query) {
  const q = query.toLowerCase();
  const filtered = q ? qoFiles.filter(f => f.name.toLowerCase().includes(q)) : qoFiles;
  qoSelectedIdx = Math.min(qoSelectedIdx, Math.max(filtered.length - 1, 0));
  $('#qo-list').innerHTML = filtered.slice(0, 30).map((f, i) =>
    `<div class="qo-item${i === qoSelectedIdx ? ' selected' : ''}"><span>${escHtml(f.name)}</span><span class="qo-path">${escHtml(f.path)}</span></div>`
  ).join('');
  $('#qo-list').querySelectorAll('.qo-item').forEach((el, i) => {
    el.addEventListener('click', () => { closeQuickOpen(); openSidebarFile(filtered[i].path); });
    el.addEventListener('mouseenter', () => { qoSelectedIdx = i; renderQoList(query); });
  });
}
$('#qo-input').addEventListener('input', e => { qoSelectedIdx = 0; renderQoList(e.target.value); });
$('#qo-input').addEventListener('keydown', e => {
  const q = e.target.value.toLowerCase();
  const filtered = q ? qoFiles.filter(f => f.name.toLowerCase().includes(q)) : qoFiles;
  if (e.key === 'ArrowDown') { e.preventDefault(); qoSelectedIdx = Math.min(qoSelectedIdx + 1, Math.min(filtered.length - 1, 29)); renderQoList(e.target.value); }
  else if (e.key === 'ArrowUp') { e.preventDefault(); qoSelectedIdx = Math.max(qoSelectedIdx - 1, 0); renderQoList(e.target.value); }
  else if (e.key === 'Enter' && filtered.length > 0) { e.preventDefault(); closeQuickOpen(); openSidebarFile(filtered[qoSelectedIdx].path); }
  else if (e.key === 'Escape') { closeQuickOpen(); }
});
$('#qo-overlay').addEventListener('click', closeQuickOpen);

// Global keyboard shortcuts
document.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'P') { e.preventDefault(); openCmdPalette(); }
  else if ((e.ctrlKey || e.metaKey) && !e.shiftKey && e.key === 'p') { e.preventDefault(); openQuickOpen(); }
  if (e.key === 'Escape') {
    if ($('#cmd-palette').classList.contains('open')) closeCmdPalette();
    if ($('#qo-palette').classList.contains('open')) closeQuickOpen();
  }
});

// Auto open editor on load for demo
setTimeout(() => {
  if (!monacoEditor) {
    // toggleEditor(); // uncomment to auto-open
  }
}, 1500);
</script>
</body>
</html>